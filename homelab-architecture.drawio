        <mxCell id="lan-note" value="Access ALL services&lt;br&gt;incl. *.local.madhur.co.in" style="html=1;text;fontSize=10;fillColor=none;strokeColor=none;align=center;" vertex="1" parent="lan-clients-zone">
          <mxGeometry x="10" y="100" width="210" height="55" as="geometry" />
