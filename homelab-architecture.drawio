        <mxCell id="infra-zone" value="&lt;b&gt;INFRASTRUCTURE&lt;/b&gt; — Internal Docker networks only, no Traefik routes" style="html=1;swimlane;startSize=30;fillColor=#e0e0e0;strokeColor=#666666;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="desktop-zone">
