        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TRAFFIC FLOW ARROWS -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Internet → Traefik (via public IP) -->
        <mxCell id="arrow-internet-traefik" value="HTTPS (443)&lt;br&gt;public IP" style="html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#006600;strokeWidth=3;fontStyle=1;fontSize=10;" edge="1" source="act-broadband" target="traefik" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="560" />
              <mxPoint x="170" y="90" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- VPN clients → wg-easy -->
        <mxCell id="arrow-vpnclient-wgeasy" value="WireGuard&lt;br&gt;UDP 51820" style="html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;fontStyle=1;fontSize=10;" edge="1" source="vpn-client-phone" target="svc-wgeasy" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LAN clients → Traefik -->
        <mxCell id="arrow-lan-traefik" value="LAN access&lt;br&gt;192.168.1.x" style="html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;fontStyle=1;fontSize=10;" edge="1" source="lan-client" target="traefik" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2170" y="360" />
              <mxPoint x="2170" y="90" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Traefik → Authentik (forward auth check) -->
        <mxCell id="arrow-traefik-authentik" value="forward auth check" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;dashed=1;fontSize=9;" edge="1" source="traefik" target="authentik-sso" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- *.local DNS note arrow -->
        <mxCell id="local-dns-note" value="&lt;b&gt;Why *.local is LAN-only:&lt;/b&gt;&lt;br&gt;DNS in Cloudflare points to&lt;br&gt;private IP (192.168.1.x)&lt;br&gt;→ RFC1918, unreachable&lt;br&gt;from public internet" style="html=1;callout;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;perimeter=mxPerimeter.RectanglePerimeter;" vertex="1" parent="1">
          <mxGeometry x="20" y="920" width="200" height="100" as="geometry" />
        </mxCell>

